# Database
DATABASE_URL=postgresql://wisdom:wisdom123@localhost:5432/wisdom_db

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMADB_HOST=http://localhost:8001

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false

# Ollama (本地模型)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# 通义千问 API
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-max

# 文心一言 API
WENXIN_API_KEY=your-wenxin-api-key
WENXIN_SECRET_KEY=your-wenxin-secret-key

# 默认使用的模型提供商: openai / qwen / wenxin / ollama
DEFAULT_MODEL_PROVIDER=openai

# 应用配置
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# 学习服务配置
LEARNING_ENABLED=false
LEARNING_SCHEDULE=0 2 * * *
DOUYIN_KEYWORDS=职场话术,领导意图,官场智慧,人情世故,社交技巧
BILIBILI_KEYWORDS=职场沟通,心理学,人际关系,情商提升
